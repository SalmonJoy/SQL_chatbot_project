GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Retrieval defaults from the project experiments
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HYBRID_DENSE_WEIGHT=0.70
HYBRID_LEXICAL_WEIGHT=0.30
AUTO_EXECUTE_MIN_SCORE=0.55
AUTO_EXECUTE_MIN_MARGIN=0.05
MAX_RESULT_ROWS_FOR_LLM=200
ENABLE_CONTEXT_REWRITE=true

# Default sidebar state for Thinking mode.
# Thinking mode uses Gemini only for uncertain top-k repository-query review.
ENABLE_GEMINI_DECISION_REVIEW=true
GEMINI_DECISION_REVIEW_TOP_K=5
GEMINI_DECISION_REVIEW_MARGIN_THRESHOLD=0.08
MAX_CONTEXT_RESULT_ROWS=20

# Runtime JSONL logging
LOG_DIR=logs
LOG_FILE=chatbot_events.jsonl
LOG_SQL_RESULT_ROWS=all
